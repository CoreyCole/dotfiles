font-family = Hasklug Nerd Font Mono Med
font-size = 14
term = xterm-256color

background = 000000
foreground = ffffff

bold-is-bright = true
bell-features = no-audio
mouse-hide-while-typing = true
clipboard-read = allow
right-click-action = paste

window-padding-x = 0
window-padding-y = 0
window-decoration = none

# 100MB lazily allocated
scrollback-limit = 100000000

# WezTerm-style shortcuts
keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+6=goto_tab:6
keybind = ctrl+7=goto_tab:7
keybind = ctrl+8=goto_tab:8
keybind = ctrl+9=last_tab
keybind = alt+enter=toggle_fullscreen
keybind = ctrl+shift+c=copy_to_clipboard:mixed
keybind = ctrl+shift+C=copy_to_clipboard:mixed
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+V=paste_from_clipboard
keybind = ctrl+key_v=paste_from_clipboard
keybind = ctrl+shift+key_v=paste_from_clipboard
keybind = alt+v=paste_from_clipboard
keybind = ctrl+shift+f=start_search
keybind = ctrl+shift+F=start_search
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+N=new_window
keybind = ctrl+shift+p=toggle_command_palette
keybind = ctrl+shift+P=toggle_command_palette
keybind = ctrl+shift+r=reload_config
keybind = ctrl+shift+R=reload_config
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+T=new_tab
